generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
}

model Account {
  id            Int           @id @default(autoincrement())
  name          String
  bankName      String
  balance       Float
  userId        Int
  createdAt     DateTime      @default(now())
  accountNumber String?
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]
}

model Transaction {
  id              Int             @id @default(autoincrement())
  amount          Float
  type            TransactionType
  description     String?
  date            DateTime
  balanceAfterTxn Float?
  rawData         Json
  accountId       Int
  categoryId      Int?
  createdAt       DateTime        @default(now())
  paymentMode     PaymentMode     @default(UNKNOWN)
  userId          Int
  account         Account         @relation(fields: [accountId], references: [id])
  category        Category?       @relation(fields: [categoryId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([accountId, date])
  @@index([paymentMode])
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  type         CategoryType?
  userId       Int
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@unique([name, userId])
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum PaymentMode {
  UPI
  NEFT
  IMPS
  RTGS
  ATM
  CASH
  CARD
  CHEQUE
  WALLET
  BANK_TRANSFER
  UNKNOWN
}

enum CategoryType {
  INCOME
  EXPENSE
  TRANSFER
}
